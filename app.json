 \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \r\n                       \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \r\n                       \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \r\n                       \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \r\n                       \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \r\n                       \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \r\n                       \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \r\n                       \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \r\n                       \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \r\n                       \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \r\n                       \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \r\n                       \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \r\n                       \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Male\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \r\n                       \"Female\", \"Female\", \"Female\", \"Female\", \"Female\", \"Female\"\r\n               )), row.names = c(NA, -362L), class = \"data.frame\")\r\n\r\n\r\n\r\nstructure(list(Ethnicity = c(\"All\", \"All\", \"White\", \"White\", \r\n                             \"Black\", \"Black\", \"Asian\", \"Asian\", \"South Asian\", \"South Asian\", \r\n                             \"Other Asian\", \"Other Asian\"), \r\n               Sex = c(\"Female\", \"Male\", \"Female\", \r\n                       \"Male\", \"Female\", \"Male\", \"Female\", \"Male\", \"Female\", \"Male\", \r\n                       \"Female\", \"Male\"), \r\n               mu_i = c(5.444, 5.484, 5.52, 5.555, 5.125, \r\n                        5.239, 5.309, 5.338, 5.29, 5.314, 5.449, 5.48), \r\n               mu_ga = c(0.067, \r\n                         0.067, 0.066, 0.066, 0.075, 0.073, 0.07, 0.07, 0.07, 0.07, 0.067, \r\n                         0.067)), class = \"data.frame\", row.names = c(NA, -12L))\r\n\r\n\r\n#ethnic_conversion <- function(E,S,GA,lms_factors) {\r\n#  d1 <- lms_factors %>% filter(Ethnicity==\"All\",Sex==S) \r\n#  d2 <- lms_factors %>% filter(Ethnicity==E,Sex==S) \r\n#  (d2$mu_i+d2$mu_ga*(GA-40) ) / (d1$mu_i+d1$mu_ga*(GA-40) )\r\n#}\r\n\r\n# --- 2. Logic Functions ---\r\ncalc_weight <- function(P, E, S, GA, lms, lms_factors) {\r\n  ddd <- lms[lms$Sex == S & lms$GA == GA, ]\r\n  \r\n  ### ethnic_conversion\r\n  d1 <- lms_factors %>% filter(Ethnicity==\"All\",Sex==S) \r\n  d2 <- lms_factors %>% filter(Ethnicity==E,Sex==S) \r\n  ddd_f <- (d2$mu_i+d2$mu_ga*(GA-40) ) / (d1$mu_i+d1$mu_ga*(GA-40) )\r\n  \r\n  #ddd_f <- lms_factors[lms_factors$Sex == S & lms_factors$Ethnicity == E, ]\r\n\r\n  zalpha <- qnorm(P / 100)\r\n  # LMS Formula\r\n  w <- ddd$M * (1 + ddd$L * ddd$S * zalpha)^(1 / ddd$L)\r\n  # Apply Ethnic Factor\r\n  final_w <- w * ddd_f\r\n  return(final_w)\r\n}\r\n\r\ncalc_percentile <- function(W, E, S, GA, lms, lms_factors) {\r\n  ddd <- lms[lms$Sex == S & lms$GA == GA, ]\r\n  #ddd_f <- lms_factors[lms_factors$Sex == S & lms_factors$Ethnicity == E, ]\r\n  ### ethnic_conversion\r\n  d1 <- lms_factors %>% filter(Ethnicity==\"All\",Sex==S) \r\n  d2 <- lms_factors %>% filter(Ethnicity==E,Sex==S) \r\n  ddd_f <- (d2$mu_i+d2$mu_ga*(GA-40) ) / (d1$mu_i+d1$mu_ga*(GA-40) )\r\n  \r\n  \r\n  # Normalize weight by removing the ethnic factor first\r\n  adjusted_W <- W / ddd_f\r\n  # Inverse LMS formula to get Z-score\r\n  zalpha <- ((adjusted_W / ddd$M)^ddd$L - 1) * 1 / (ddd$L * ddd$S)\r\n  PP <- pnorm(zalpha) * 100\r\n  return(PP)\r\n}\r\n\r\nlms_factors <- lms_factors %>%\r\n  mutate(Ethnicity = if_else(Ethnicity==\"South Asian\",\"*South Asian\",Ethnicity))%>%\r\n  mutate(Ethnicity = if_else(Ethnicity==\"Other Asian\",\"*Other Asian\",Ethnicity))\r\n\r\n# --- 3. UI Section ---\r\nui <- dashboardPage(\r\n  dashboardHeader(title = \"Birthweight Centile Calculator\"),\r\n  dashboardSidebar(\r\n    sidebarMenu(\r\n      menuItem(\"Calculator\", tabName = \"calc\", icon = icon(\"calculator\")),\r\n      # Inputs\r\n      numericInput(\"ga\", \"Gestational Age (Weeks):\", value = 40, min = 24, max = 42, step = 1),\r\n      selectInput(\"sex\", \"Gender:\", choices = c(\"Male\", \"Female\")),\r\n      selectInput(\"ethnicity\", \"Ethnic Origin:\", choices = unique(lms_factors$Ethnicity)),\r\n      hr(),\r\n      radioButtons(\"mode\", \"Calculation Mode:\",\r\n                   choices = list(\"Find Weight from Centile\" = \"w_from_p\", \r\n                                  \"Find Centile from Weight\" = \"p_from_w\")),\r\n      #conditionalPanel(\r\n      #  condition = \"input$mode == 'w_from_p'\",\r\n      #  numericInput(\"p_input\", \"Desired Centile (0.4 - 99.6):\", value = 50, min = 0.4, max = 99.6)\r\n      #),\r\n      #conditionalPanel(\r\n      #  condition = \"input$mode == 'p_from_w'\",\r\n      #  numericInput(\"w_input\", \"Observed Birthweight (g):\", value = 3500, min = 200, max = 6000)\r\n      #)\r\n      # This acts as a placeholder for the dynamic input\r\n      uiOutput(\"dynamic_input\")\r\n    )\r\n  ),\r\n  dashboardBody(\r\n    fluidRow(\r\n      valueBoxOutput(\"resultBox\", width = 6),\r\n      valueBoxOutput(\"statusBox\", width = 6)\r\n    ),\r\n    fluidRow(\r\n      box(title = \"Distribution at Selected Gestation\", status = \"primary\", solidHeader = TRUE, \r\n          plotOutput(\"distPlot\"), width = 6),\r\n      box(title = \"Gestational Growth Curves\", status = \"info\", solidHeader = TRUE, \r\n          plotOutput(\"growthPlot\"), width = 6)\r\n    ),\r\n    tags$footer(\r\n      style = \"padding: 10px; color: gray; font-size: 1.5em;\",\r\n      \"Footnote: This calculator uses LMS coefficients derived from Tom Norris (2018) national birthweight references, \r\n       adjusted by ethnic-specific factors from Freni-Sterrantino et al. (2019). \r\n       Centiles are calculated using the LMS transformation. Clinical decisions should not be based solely on this tool.\",\r\n      br(),\r\n      \"*South Asian (Indian, Pakistani and Bangladeshi) and other Asian (any other Asian background) are two subsets derived from Asian.\"\r\n    )\r\n  )\r\n)\r\n\r\n# --- 4. Server Section ---\r\nserver <- function(input, output) {\r\n  \r\n  # Calculate the main result reactively\r\n  calc_res <- reactive({\r\n    if (input$mode == \"w_from_p\") {\r\n      req(input$p_input)\r\n      res <- calc_weight(input$p_input, input$ethnicity, input$sex, input$ga, lms, lms_factors)\r\n      return(list(val = unname(round(res, 0)), unit = \"grams\", label = paste0(input$p_input, \"th Centile Weight\")))\r\n    } else {\r\n      req(input$w_input)\r\n      res <- calc_percentile(input$w_input, input$ethnicity, input$sex, input$ga, lms, lms_factors)\r\n      return(list(val = unname(round(res, 1)), unit = \"th Centile\", label = \"Calculated Centile\"))\r\n    }\r\n  })\r\n  \r\n  # Reactive clinical classification\r\n  clinical_status <- reactive({\r\n    # We need the percentile regardless of the mode\r\n    p <- if(input$mode == \"p_from_w\") {\r\n      calc_res()$val \r\n    } else {\r\n      input$p_input\r\n    }\r\n    \r\n    # SILENCE FIX: Stop here if p is NULL or empty\r\n    req(p)\r\n    \r\n    if (p < 10) {\r\n      return(list(label = \"SGA\", desc = \"Small for Gestational Age\", color = \"red\", icon = \"arrow-down\"))\r\n    } else if (p > 90) {\r\n      return(list(label = \"LGA\", desc = \"Large for Gestational Age\", color = \"orange\", icon = \"arrow-up\"))\r\n    } else {\r\n      return(list(label = \"AGA\", desc = \"Appropriate for Gestational Age\", color = \"green\", icon = \"check\"))\r\n    }\r\n  })\r\n  \r\n  output$dynamic_input <- renderUI({\r\n    if (input$mode == \"w_from_p\") {\r\n      numericInput(\"p_input\", \"Desired Centile (0.4 - 99.6):\", \r\n                   value = 50, min = 0.4, max = 99.6, step = 0.1)\r\n    } else {\r\n      numericInput(\"w_input\", \"Observed Birthweight (g):\", \r\n                   value = 3500, min = 200, max = 6000, step = 10)\r\n    }\r\n  })\r\n  \r\n  \r\n  # Value Box Result\r\n  output$resultBox <- renderValueBox({\r\n    res <- calc_res()\r\n    valueBox(\r\n      paste(res$val, res$unit), res$label, icon = icon(\"baby\"),\r\n      color = ifelse(input$mode == \"w_from_p\", \"blue\", \"purple\")\r\n    )\r\n  })\r\n  \r\n  output$statusBox <- renderValueBox({\r\n    status <- clinical_status()\r\n    valueBox(\r\n      status$label, status$desc, icon = icon(status$icon),\r\n      color = status$color\r\n    )\r\n  })\r\n  \r\n\r\n  \r\n  # Plotting the Distribution\r\n  output$distPlot <- renderPlot({\r\n    # 1. Grab inputs once at the start of the reactive context\r\n    # This prevents the \"object not found\" error inside the loop\r\n    current_ga <- input$ga\r\n    current_eth <- input$ethnicity\r\n    current_sex <- input$sex\r\n    \r\n    # Generate a range of percentiles to build the curve\r\n    p_seq <- seq(0.1, 99.9, by = 0.5)\r\n    weights <- sapply(p_seq, function(p) calc_weight(p, current_eth, current_sex, current_ga, lms, lms_factors))\r\n    \r\n    df_plot <- data.frame(p = p_seq, Weight = weights)\r\n    \r\n    # 3. Calculate clinical thresholds for this specific baby\r\n    w_sga <- calc_weight(10, current_eth, current_sex, current_ga, lms, lms_factors)\r\n    w_lga <- calc_weight(90, current_eth, current_sex, current_ga, lms, lms_factors)\r\n    \r\n    # Identify the user's specific point\r\n    current_w <- if(input$mode == \"w_from_p\") calc_res()$val else input$w_input\r\n    \r\n\r\n    p_plot <- ggplot(df_plot, aes(x = Weight)) +\r\n      # Main density area\r\n      geom_area(stat = \"density\", fill = \"steelblue\", alpha = 0.2) +\r\n      \r\n      # Threshold Vertical Lines\r\n      geom_vline(xintercept = w_sga, color = \"red\", linetype = \"dotted\", size = 1) +\r\n      geom_vline(xintercept = w_lga, color = \"orange\", linetype = \"dotted\", size = 1) +\r\n      geom_vline(xintercept = current_w, color = \"red\", linetype = \"dashed\", size = 1.2) +\r\n      labs(x = \"Birthweight (g)\", y = \"Density\", \r\n           title = paste(\"Weight Distribution for\", input$ethnicity, input$sex, \"at\", input$ga, \"Weeks\")) +\r\n      theme_minimal() +\r\n      xlim(250,5250)+\r\n      theme(text = element_text(size = 14))\r\n    \r\n    if (!is.null(current_w)) {\r\n      p_plot <- p_plot + annotate(\"text\", x = current_w, y = 0, label = \"This Baby\", vjust = -1, color = \"red\") \r\n    }\r\n    \r\n    p_plot\r\n      \r\n  })\r\n  \r\n  output$growthPlot <- renderPlot({\r\n    req(input$ga, input$sex, input$ethnicity)\r\n    \r\n    # 1. Get the current baby's specific data\r\n    res <- calc_res()\r\n    \r\n    # Determine the weight and the percentile to track\r\n    current_w <- if(input$mode == \"w_from_p\") res$val else input$w_input\r\n    # This is the centile we want to plot across the whole range\r\n    current_p <- if(input$mode == \"w_from_p\") input$p_input else res$val\r\n    \r\n    # 2. Setup the range and generate the SINGLE curve for this baby's centile\r\n    ga_range <- 24:42\r\n    \r\n    # Generate the Main Curve\r\n    curve_df <- data.frame(GA = ga_range) %>%\r\n      rowwise() %>%\r\n      mutate(Weight = calc_weight(current_p, input$ethnicity, input$sex, GA, lms, lms_factors))\r\n    \r\n    # NEW: Generate Reference Curves (10th and 90th)\r\n    ref_curves <- expand.grid(GA = ga_range, P = c(10, 90)) %>%\r\n      rowwise() %>%\r\n      mutate(Weight = calc_weight(P, input$ethnicity, input$sex, GA, lms, lms_factors))\r\n    \r\n    \r\n    current_baby <- data.frame(GA = input$ga, Weight = current_w)\r\n    \r\n    # 3. Build the plot\r\n    ggplot() +\r\n      # Add the 10th and 90th percentile dotted lines\r\n      geom_line(data = ref_curves, aes(x = GA, y = Weight, group = P), \r\n                color = \"grey60\", linetype = \"dotted\", size = 0.8) +\r\n      \r\n      # Label the reference lines at the end\r\n      geom_text(data = filter(ref_curves, GA == 42), \r\n                aes(x = GA, y = Weight, label = paste0(P, \"th\")),\r\n                hjust = -0.2, size = 4, color = \"grey60\") +\r\n      \r\n      # The single growth curve for the baby's specific percentile\r\n      geom_line(data = curve_df, aes(x = GA, y = Weight), \r\n                color = \"steelblue\", size = 1.2, alpha = 0.8) +\r\n      \r\n      # Label for the main curve\r\n      geom_text(data = filter(curve_df, GA == 42), \r\n                aes(x = GA, y = Weight, label = paste0(round(current_p, 1), \"th\")),\r\n                hjust = -0.2, fontface = \"bold\", color = \"steelblue\", size = 5) +\r\n      \r\n      # The Current Baby (The Dot)\r\n      geom_point(data = current_baby, aes(x = GA, y = Weight), \r\n                 color = \"black\", size = 5, shape = 21, fill = \"yellow\", stroke = 2) +\r\n      \r\n      # Label for the dot\r\n      geom_text(data = current_baby, aes(x = GA, y = Weight, label = \"This Baby\"), \r\n                vjust = -1.5, fontface = \"bold\") +\r\n      \r\n      # Scale and formatting\r\n      ylim(0, 5250) +\r\n      xlim(24, 44) + # Increased xlim to accommodate labels\r\n      labs(x = \"Gestational Age (Weeks)\", y = \"Birthweight (g)\",\r\n           title = paste(\"Growth curve for the \", round(current_p, 1), \"th Centile\", sep=\"\"),\r\n           subtitle = paste(input$ethnicity, input$sex)) +\r\n      theme_minimal() +\r\n      theme(text = element_text(size = 14))\r\n    \r\n  })\r\n  \r\n}\r\n\r\nshinyApp(ui, server)","type":"text"}]
